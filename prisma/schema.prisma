generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  editor
  approver
}

enum SourceType {
  article
  youtube
}

enum PublicationStatus {
  draft
  processing
  needs_approval
  approved
  publishing
  partially_published
  published
  failed
}

enum ExecutionStatus {
  ok
  needs_approval
  retryable_error
  fatal_error
  skipped
}

enum IntegrationStatus {
  healthy
  warning
  disconnected
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum PublishAttemptStatus {
  draft
  queued
  published
  failed
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(editor)
  accounts      Account[]
  sessions      Session[]
  approvals     ApprovalDecision[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PublicationTask {
  id                 String             @id @default(cuid())
  correlationId      String             @unique
  sourceUrl          String
  normalizedUrl      String
  sourceType         SourceType
  title              String
  status             PublicationStatus
  brand              String
  locale             String
  tone               String
  useAiImage         Boolean            @default(false)
  requestedChannels  String[]
  totalEstimatedCost Float              @default(0)
  totalLatencyMs     Int                @default(0)
  retryCount         Int                @default(0)
  lastRunStage       String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sourceAssets       SourceAsset[]
  channelDrafts      ChannelDraft[]
  approvalDecisions  ApprovalDecision[]
  publishAttempts    PublishAttempt[]
  executionEvents    ExecutionEvent[]
}

model SourceAsset {
  id               String          @id @default(cuid())
  taskId           String
  sourceType       SourceType
  normalizedUrl    String
  canonicalDate    DateTime
  title            String
  author           String?
  summary          String?         @db.Text
  transcriptStatus String
  extractionStatus ExecutionStatus
  task             PublicationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ChannelDraft {
  id                 String          @id @default(cuid())
  taskId             String
  channel            String
  headline           String
  body               String          @db.Text
  characterCount     Int
  requiresApproval   Boolean         @default(true)
  approvedRevision   Int             @default(1)
  validationWarnings String[]
  imagePrompt        String?         @db.Text
  task               PublicationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ApprovalDecision {
  id         String         @id @default(cuid())
  taskId      String
  userId      String?
  channel     String
  status      ApprovalStatus
  note        String?       @db.Text
  reviewedAt  DateTime?
  task        PublicationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PublishAttempt {
  id             String               @id @default(cuid())
  taskId          String
  channel         String
  accountId       String
  idempotencyKey  String              @unique
  status          PublishAttemptStatus
  publishedAt     DateTime?
  externalPostId  String?
  lastError       String?             @db.Text
  task            PublicationTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model ExecutionEvent {
  id               String          @id @default(cuid())
  taskId           String
  stage            String
  status           ExecutionStatus
  message          String          @db.Text
  latencyMs        Int
  estimatedCostUsd Float           @default(0)
  createdAt        DateTime        @default(now())
  task             PublicationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model IntegrationBinding {
  id            String            @id @default(cuid())
  provider      String
  environment   String
  status        IntegrationStatus
  scopes        String[]
  lastRotatedAt DateTime
}

model PromptTemplate {
  id          String   @id @default(cuid())
  brand       String
  channel     String
  locale      String
  contentType String
  version     Int
  status      String
  template    String   @db.Text
}
