{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowResult",
  "type": "object",
  "required": ["status", "payload", "metrics"],
  "properties": {
    "status": {
      "enum": ["ok", "needs_approval", "retryable_error", "fatal_error", "skipped"]
    },
    "payload": { "type": "object" },
    "metrics": {
      "type": "object",
      "required": ["durationMs"],
      "properties": {
        "durationMs": { "type": "number", "minimum": 0 },
        "estimatedCostUsd": { "type": "number", "minimum": 0 },
        "retries": { "type": "integer", "minimum": 0 }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message", "retriable"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retriable": { "type": "boolean" },
        "context": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
